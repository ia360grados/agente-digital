# ============================================================
#  Plantilla de credenciales — copiar a .env (lo hace install.sh)
#  El wizard.sh rellena estos valores en la máquina del cliente.
#  NUNCA subir el .env real a git.
# ============================================================

# Token permanente de la app de Meta (WhatsApp Cloud API)
WHATSAPP_TOKEN=

# ID del número de teléfono en Meta (no es el número, es su ID)
WHATSAPP_PHONE_ID=

# Token inventado para verificar el webhook (el mismo que pongas en Meta)
WHATSAPP_VERIFY_TOKEN=

# Números que pueden hablar con el agente (E.164 sin +, separados por comas)
# Ej: 34600111222,34600333444  — vacío = cualquiera (no recomendado)
NUMEROS_AUTORIZADOS=

# Puerto local del webhook
PUERTO=3000
